});

// 主题切换
function toggleTheme() {
  const html = document.documentElement;
  const current = html.getAttribute("data-theme") || "dark";
  const next = current === "dark" ? "light" : "dark";
  setTheme(next);
  document.getElementById("menuDropdown")?.classList.remove("show");
  showToast(next === "light" ? "☀ 白天模式" : "🌙 夜间模式");
}

function setTheme(theme) {
  document.documentElement.setAttribute("data-theme", theme);
  localStorage.setItem("yanchi_theme", theme);
  document.querySelector('meta[name="theme-color"]').content =
    theme === "light" ? "#f5f5f7" : "#0d0d0d";
}

function initTheme() {
  const saved = localStorage.getItem("yanchi_theme") || "dark";
  setTheme(saved);
}

// ── 系统设置 ─────────────────────────────
async function showSettings() {
  document.getElementById("menuDropdown").classList.remove("show");
  document.getElementById("settingsOverlay").classList.add("show");
  document.getElementById("sStatus").style.display = "none";
  try {
    const res = await fetch("/api/settings");
    if (!res.ok) throw new Error("获取失败");
    const data = await res.json();
    document.getElementById("sBaseUrl").value = data.base_url || "";
    document.getElementById("sApiKey").value = data.api_key || "";
    document.getElementById("sModel").value = data.model || "";
    document.getElementById("sQwenKey").value = data.qwen_api_key || "";
    document.getElementById("sQwenUrl").value = data.qwen_base_url || "";
  } catch (e) {
    document.getElementById("sStatus").textContent = "加载失败: " + e.message;
    document.getElementById("sStatus").style.display = "block";
  }
}

function closeSettings() {
  document.getElementById("settingsOverlay").classList.remove("show");
}

async function saveSettings() {
  const body = {
    base_url: document.getElementById("sBaseUrl").value.trim(),
    api_key: document.getElementById("sApiKey").value.trim(),
    model: document.getElementById("sModel").value.trim(),
    qwen_api_key: document.getElementById("sQwenKey").value.trim(),
    qwen_base_url: document.getElementById("sQwenUrl").value.trim(),
  };
  const status = document.getElementById("sStatus");
  status.style.display = "none";
  try {
    const res = await fetch("/api/settings", {
      method: "PUT",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(body),
    });
    if (!res.ok) throw new Error(await res.text());
    status.textContent = "✅ 已保存并生效";
    status.style.display = "block";
    status.style.color = "var(--green)";
    setTimeout(() => { closeSettings(); }, 1500);
  } catch (e) {
    status.textContent = "❌ 保存失败: " + e.message;
    status.style.display = "block";
    status.style.color = "var(--rose)";
  }
}

function menuAction(type) {
  document.getElementById("menuDropdown").classList.remove("show");
  if (type === "sessions") showSessionSheet();
  else if (type === "search") showQuickSearch();
  else if (type === "note") openTodayNote();
  else if (type === "consolidate") consolidateMemories();
  else if (type === "export") exportChat();
}

// ── 模型切换 ─────────────────────────────
async function loadModelInfo() {
  try {
    const res = await fetch("/api/model");
    if (!res.ok) throw new Error();
    const data = await res.json();
    const label = document.getElementById("currentModelLabel");
    label.textContent = data.model;
    return data;
  } catch { return null; }
}

function showModelPicker() {
  document.getElementById("menuMain").style.display = "none";
  document.getElementById("menuModel").style.display = "block";
  loadModelInfo().then(data => {
    if (!data) return;
    const list = document.getElementById("modelList");
    list.innerHTML = data.available.map(m =>
      `<button class="model-opt" onclick="switchModel('${m}')">
        <span class="check">${m === data.model ? "✓" : ""}</span>
        ${m}
      </button>`
    ).join("");
  });
}

function showMenuMain() {
  document.getElementById("menuModel").style.display = "none";
  document.getElementById("menuMain").style.display = "block";
}

async function switchModel(model) {
  try {
    const res = await fetch("/api/model", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ model })
    });
    if (!res.ok) throw new Error("切换失败");
    showToast("已切换到 " + model);
    document.getElementById("currentModelLabel").textContent = model;
    showMenuMain();
    document.getElementById("menuDropdown").classList.remove("show");
  } catch (e) {
    showError("模型切换: " + e.message);
  }
}

// 初始化模型标签
loadModelInfo();

// 从后端同步头像（首次访问或无 localStorage 时）
async function syncAvatarFromServer(type) {
  if (localStorage.getItem("avatar_" + type)) return;
  try {
    const res = await fetch("/api/avatar/" + type);
    if (!res.ok) return;
    const blob = await res.blob();
    const reader = new FileReader();
    reader.onload = function(e) {
      localStorage.setItem("avatar_" + type, e.target.result);
      reloadChat();
    };
    reader.readAsDataURL(blob);
  } catch (e) {}
}
syncAvatarFromServer("ai");
syncAvatarFromServer("user");

function showQuickSearch() {
  document.getElementById("searchOverlay").classList.add("show");
  document.getElementById("chat").style.display = "none";
  document.getElementById("inputBar").style.display = "none";
  document.getElementById("suggestRemember").style.display = "none";
  setTimeout(() => document.getElementById("soInput").focus(), 100);
  document.getElementById("soResults").innerHTML =
    '<div style="text-align:center;padding:30px;color:var(--text-dim);font-size:13px">输入关键词搜索</div>';
}

function closeQuickSearch() {
  document.getElementById("searchOverlay").classList.remove("show");
  document.getElementById("chat").style.display = "flex";
  document.getElementById("inputBar").style.display = "flex";
  document.getElementById("suggestRemember").style.display = "";
}

async function doQuickSearch() {
  const q = document.getElementById("soInput").value.trim();
  if (!q) return;
  const container = document.getElementById("soResults");
  container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--text-dim);font-size:13px">搜索中……</div>';
  try {
    const res = await fetch("/api/search", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ query: q, scope: "all" })
    });
    if (!res.ok) throw new Error("搜索失败");
    const data = await res.json();
    if (data.count === 0) {
      container.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-dim);font-size:13px">没有找到匹配内容</div>';
      return;
    }
    const re = new RegExp("(" + q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&") + ")", "gi");
    let html = `<div style="font-size:11px;color:var(--text-dim);padding:4px 0 8px;opacity:0.5">找到 ${data.count} 条结果</div>`;
    for (const r of data.results) {
      const icon = r.source === "session" ? "💬"
                  : r.source === "chat" ? "💬"
                  : r.file.includes("auto-memory") ? "🧠"
                  : r.file.includes("today-note") ? "📝"
                  : "📄";
      const hl = escapeHtml(r.text).replace(re, '<mark>$1</mark>');
      html += `<div class="so-result" onclick="soResultClicked('${escapeHtml(r.file)}')">
        <div class="sr-meta">${icon} ${escapeHtml(r.file.slice(0, 50))}</div>
        <div class="sr-text">${hl}</div>
      </div>`;
    }
    container.innerHTML = html;
  } catch (e) {
    container.innerHTML = `<div style="text-align:center;padding:40px;color:var(--rose-dim);font-size:13px">${escapeHtml(e.message)}</div>`;
  }
}

function soResultClicked(file) {
  if (file.startsWith("session/")) { showToast("当前会话不支持跳转"); return; }
  closeQuickSearch();
  // Open in timeline viewer
  const tv = document.getElementById("timelineView");
  if (!tv.classList.contains("show")) toggleTimeline();
  setTimeout(() => viewTimelineEntry(file), 300);
}

// ════════════════════════════════════════════
// ══  Today Note  ═══════════════════════════
// ════════════════════════════════════════════
async function openTodayNote() {
  if (history.length < 2) {
    showToast("还没有足够对话可以记笔记");
    return;
  }
  showToast("砚迟正在写日记……");
  try {
    const res = await fetch("/api/today-note", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ history: history.slice(-30) })
    });
    if (!res.ok) throw new Error((await res.json().catch(() => ({}))).detail || "生成失败");
    const data = await res.json();
    if (data.saved) {
      showToast("砚迟日记写好了 ✧");
      // 如果已经在时间线，刷新；否则打开时间线
      const tv = document.getElementById("timelineView");
      if (tv.classList.contains("show")) {
        loadTimeline();
      } else {
        toggleTimeline();
      }
    } else {
      showToast("笔记生成失败");
    }
  } catch (e) {
    showError("今日笔记: " + e.message);
  }
}

// ════════════════════════════════════════════
// ══  Session Sheet  ════════════════════════
// ════════════════════════════════════════════
function showSessionSheet() {
  renderSessionSheet();
  document.getElementById("sessionOverlay").classList.add("show");
  document.getElementById("sessionSidebar").classList.add("show");
}

function hideSessionSheet() {
  document.getElementById("sessionOverlay").classList.remove("show");
  document.getElementById("sessionSidebar").classList.remove("show");
}

function renderSessionSheet() {
  const list = getSessionList();
  const current = getSessionId();
  const container = document.getElementById("sheetList");
  if (list.length === 0) {
    container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text-dim);font-size:13px">还没有会话</div>';
    return;
  }
  container.innerHTML = list.map(s => {
    const active = s.id === current ? " active" : "";
    const title = escapeHtml(s.title || "新会话");
    const badge = s.msgCount ? Math.ceil(s.msgCount / 2) + " 轮" : "空";
    return `<div class="sb-item${active}" data-sid="${s.id}">
      <span class="s-name">${title}</span>
      <span class="s-badge">${badge}</span>
      <button class="s-del" data-del="${s.id}" title="删除">✕</button>
    </div>`;
  }).join("");

  container.querySelectorAll(".sb-item").forEach(el => {
    el.addEventListener("click", (e) => {
      if (e.target.closest(".s-del") || e.target.closest(".s-name-edit")) return;
      switchSession(el.dataset.sid);
    });
  });
  container.querySelectorAll(".s-del").forEach(el => {
    el.addEventListener("click", (e) => {
      e.stopPropagation();
      deleteSession(el.dataset.del);
    });
  });
  container.querySelectorAll(".s-name").forEach(el => {
    el.addEventListener("dblclick", (e) => {
      e.stopPropagation();
      const item = el.closest(".sb-item");
      if (item) startRenameSession(item);
    });
  });
}

function startRenameSession(item) {
  const sid = item.dataset.sid;
  const list = getSessionList();
  const entry = list.find(s => s.id === sid);
  if (!entry) return;

  const nameEl = item.querySelector(".s-name");
  if (!nameEl) return;
  const oldTitle = entry.title || "";

  const input = document.createElement("input");
  input.type = "text";
  input.className = "s-name-edit";
  input.value = oldTitle;
  input.style.cssText = "width:100%;background:var(--surface);border:1px solid var(--ink-dim);border-radius:4px;color:var(--text);font-size:12px;padding:2px 4px;outline:none;font-family:inherit";
  nameEl.style.display = "none";
  nameEl.after(input);
  input.focus();
  input.select();

  function finish(confirmed) {
    if (confirmed) {
      const newTitle = input.value.trim() || oldTitle;
      entry.title = newTitle;
      saveSessionList(list);
      nameEl.textContent = escapeHtml(newTitle);
    }
    input.remove();
    nameEl.style.display = "";
  }

  input.addEventListener("blur", () => finish(true));
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter") { e.preventDefault(); finish(true); }
    if (e.key === "Escape") { e.preventDefault(); finish(false); }
  });
}

function newSession() {
  saveCurrentSession();
  history = [];
  msgCount = 0;
  const sid = "yanchi_" + Date.now().toString(36) + "_" + Math.random().toString(36).slice(2, 8);
  setSessionId(sid);
  const list = getSessionList();
  list.unshift({ id: sid, title: "新会话", msgCount: 0 });
  saveSessionList(list);
  document.querySelectorAll(".msg-row").forEach(m => m.remove());
  hideSessionSheet();
  showToast("新建会话");
}

function switchSession(sid) {
  if (sid === getSessionId()) { hideSessionSheet(); return; }
  saveCurrentSession();
  history = getSessionHistory(sid);
  msgCount = Math.floor(history.length / 2);
  setSessionId(sid);
  document.querySelectorAll(".msg-row").forEach(m => m.remove());
  for (const msg of history) {
    addMsg(msg.content, msg.role === "user" ? "user" : "ai");
  }
  restoreBackendSession(sid, history);
  hideSessionSheet();
}

function deleteSession(sid) {
  const list = getSessionList();
  const idx = list.findIndex(s => s.id === sid);
  if (idx === -1) return;
  fetch("/session/" + sid, { method: "DELETE" }).catch(() => {});
  localStorage.removeItem("yanchi_hist_" + sid);
  list.splice(idx, 1);
  saveSessionList(list);
  if (sid === getSessionId()) {
    history = [];
    msgCount = 0;
    document.querySelectorAll(".msg-row").forEach(m => m.remove());
    if (list.length > 0) {
      switchSession(list[0].id);
    } else {
      newSession();
    }
  } else {
    renderSessionSheet();
  }
  showToast("已删除");
}

// ════════════════════════════════════════════
// ══  Health Check  ═════════════════════════
// ════════════════════════════════════════════
async function checkHealth() {
  try {
    const res = await fetch(HEALTH_URL, { signal: AbortSignal.timeout(3000) });
    statusDot.className = res.ok ? "status-dot online" : "status-dot offline";
  } catch {
    statusDot.className = "status-dot offline";
  }
}

// ════════════════════════════════════════════
// ══  Context Menu & Scroll Bottom  ════════
// ════════════════════════════════════════════
let _ctxTarget = null;

document.addEventListener("contextmenu", (e) => {
  const row = e.target.closest(".msg-row");
  if (!row) {
    document.getElementById("msgCtxMenu").classList.remove("show");
    return;
  }
  e.preventDefault();
  _ctxTarget = row;
  const menu = document.getElementById("msgCtxMenu");
  menu.style.left = Math.min(e.clientX, window.innerWidth - 100) + "px";
  menu.style.top = Math.min(e.clientY, window.innerHeight - 50) + "px";
  menu.classList.add("show");
});
document.addEventListener("click", (e) => {
  if (!e.target.closest("#msgCtxMenu")) {
    document.getElementById("msgCtxMenu").classList.remove("show");
  }
});

function deleteMsg() {
  document.getElementById("msgCtxMenu").classList.remove("show");
  if (!_ctxTarget) return;
  if (!confirm("删除这条消息？")) return;

  const type = _ctxTarget.classList.contains("ai") ? "assistant" : "user";
  const body = _ctxTarget.querySelector(".msg");
  const textEl = body?.querySelector("div:first-child");
  const content = textEl?.textContent || "";

  // 从 history 删除匹配项
  const idx = history.findIndex(m => m.role === type && m.content === content);
  if (idx !== -1) history.splice(idx, 1);

  // 如果相邻消息是对应的角色，一起删掉保持交替
  const ctxMsgIdx = Array.from(chat.children).indexOf(_ctxTarget);
  if (ctxMsgIdx >= 0) {
    const nextRow = chat.children[ctxMsgIdx + 1];
    if (nextRow && nextRow.classList.contains("msg-row")) {
      const nextType = nextRow.classList.contains("ai") ? "assistant" : "user";
      if (nextType !== type) {
        const nextBody = nextRow.querySelector(".msg");
        const nextText = nextBody?.querySelector("div:first-child")?.textContent || "";
        const delIdx = history.findIndex(m => m.role === nextType && m.content === nextText);
        if (delIdx !== -1) history.splice(delIdx, 1);
        nextRow.remove();
      }
    }
  }

  _ctxTarget.remove();
  _ctxTarget = null;
}

// ── Scroll-to-bottom ──────────────────────────
const chatEl = document.getElementById("chat");
chatEl.addEventListener("scroll", () => {
  const btn = document.getElementById("scrollBottomBtn");
  const dist = chatEl.scrollHeight - chatEl.clientHeight - chatEl.scrollTop;
  btn.classList.toggle("show", dist > 200);
});
document.getElementById("scrollBottomBtn").addEventListener("click", () => {
  chatEl.scrollTo({ top: chatEl.scrollHeight, behavior: "smooth" });
});
(function init() {
  initTheme();

  const sid = getSessionId();
  let list = getSessionList();
  let entry = list.find(s => s.id === sid);
  if (!entry) {
    list.unshift({ id: sid, title: "新会话", msgCount: 0 });
    saveSessionList(list);
  }
  const savedHist = getSessionHistory(sid);
  if (savedHist.length > 0) {
    history = savedHist;
    for (const msg of history) {
      addMsg(msg.content, msg.role === "user" ? "user" : "ai");
    }
    msgCount = Math.floor(history.length / 2);
    restoreBackendSession(sid, history);
  }
  checkHealth();
  setInterval(checkHealth, 15000);

  // Click title → timeline
  document.getElementById("titleBtn").addEventListener("click", toggleTimeline);
})();
</script>

<!-- PWA 注册 -->
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js');
    });
  }
</script>
</body>
</html>
