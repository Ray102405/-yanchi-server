# ── 砚迟后端配置 ──────────────────────────────────────

# LLM 后端: claude / openai / ollama（默认 ollama）
PROVIDER=ollama

# ── Claude API（PROVIDER=claude 时必填）──
# 从 https://console.anthropic.com 获取
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6-20251001

# ── OpenAI API（PROVIDER=openai 时必填）──
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── Ollama（PROVIDER=ollama 时使用）──
# 默认 http://localhost:11434，一般不用改
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.1

# ── 服务端口 ──
PORT=8000
